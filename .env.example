# Bahiran Delivery - Environment Configuration

# ─── Node.js Server (serves frontend) ────────────────────────────────────────
PORT=3000
API_BASE_URL=https://your-ngrok-url.ngrok-free.app
BAHIRAN_API_BASE_URL=https://api.bahirandelivery.cloud

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_from_botfather

# ─── Flask API (new auth backend) ─────────────────────────────────────────────
FLASK_PORT=5000
FLASK_DEBUG=false
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_64_char_random_secret_here

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key

# ─── Chapa Payment ────────────────────────────────────────────────────────────
CHAPA_SECRET=CHASECK-your_secret_here
# Optional: override callback_url / return_url sent to Chapa
# CHAPA_CALLBACK_URL=https://api.bahirandelivery.cloud/api/v1/webhooks/chapa
# CHAPA_RETURN_URL=https://your-mini-app-url/
